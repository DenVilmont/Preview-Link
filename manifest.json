{
   "action": {
      "default_icon": {
         "128": "icons/icon-off.png",
         "16": "icons/icon-off.png",
         "32": "icons/icon-off.png",
         "48": "icons/icon-off.png"
      },
      "default_popup": "popup.html",
      "default_title": "Preview Link"
   },
   "background": {
      "service_worker": "background.js"
   },
   "content_scripts": [ {
      "all_frames": true,
      "js": [ "content.js" ],
      "matches": [ "\u003Call_urls>" ]
   }, {
      "all_frames": true,
      "js": [ "iframe-handler.js" ],
      "matches": [ "\u003Call_urls>" ]
   } ],
   "description": "Without Tabs: preview any link's content instantly on hover—no extra tabs needed.",
   "host_permissions": [ "\u003Call_urls>" ],
   "icons": {
      "128": "icons/icon-off.png",
      "16": "icons/icon-off.png",
      "32": "icons/icon-off.png",
      "48": "icons/icon-off.png"
   },
   "key": "",
   "manifest_version": 3,
   "name": "Preview Link",
   "permissions": [ "storage" ],
   "version": "1.0.3"
}
